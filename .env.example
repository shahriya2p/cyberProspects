# Path to the source archive (the 26GB bz2 the client provided).
# Only needed to rebuild the dataset; not required to run the app.
CYBERPROSPECT_SOURCE=../b2_download_file_by_id.bz2

# Which IP-hash buckets to process. Buckets are a hash partition of the IP
# space, so a contiguous range is a uniform sample of the whole internet.
CYBERPROSPECT_BUCKETS=0 1 2 3

# Where the built database lands / is read from.
CYBERPROSPECT_DB=pipeline/data/derived/app.duckdb
